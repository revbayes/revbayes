################################################################################
#
# RevBayes Validation Test: Brownian motion model with multiple samples
# 
# Model: Continuous character(s) evolve under BM model.
#            
#
# authors: Haoqing Du + BTK
#
################################################################################

seed(12345)

#######################
# Reading in the Data #
#######################

###### This just defines a single model for all sites #######

### Read in sequence data for both genes

data <- readContinuousCharacterData("data/Drosophila_tpm.nex")
# original data Drosophila_27936_BF.nex

# Get some useful variables from the data. We need these later on.
taxa <- data.taxa()

# set my move index
mvi = 0

##############
# Tree model #
##############

psi <- readTrees( "data/Drosophila.tre" )[1]
root_age := psi.rootAge()


#######################
# BM-Model Parameters #
#######################

sigma ~ dnExponential( 10.0 )

moves[++mvi] = mvScale(sigma, lambda=1.0, tune=true, weight=2.0) 

### Within-species variances
taxon_map = readTaxonData("data/Drosophila_species_map.txt")

# Assume one variance parameter per species
for (i in 1:psi.ntips()) {

    species_sd[i] ~ dnExp(1.0)
    moves.append( mvScale(species_sd[i], weight=2.0) )
    species_var[i] := species_sd[i] * species_sd[i]

}

###################
# PhyloCTMC Model #
###################

traits ~ dnPhyloBrownianMultiSampleREML(psi, branchRates=sigma, withinSpeciesVariances=species_var, nSites=1, taxa = taxon_map)

# attach the data
traits.clamp(data)


#############
# THE Model #
#############

# We define our model.
# We can use any node of our model as a handle, here we chose to use the rate matrix.
mymodel = model(psi)


mni = 0
monitors[++mni] = mnModel(filename="output/BM_multisamples.log",printgen=10, separator = TAB)

mymcmc = mcmc(mymodel, monitors, moves)
mymcmc.burnin(generations=500,tuningInterval=100)
mymcmc.run(generations=500)


# you may want to quit RevBayes now
q()

