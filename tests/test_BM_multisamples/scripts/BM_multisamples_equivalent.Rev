################################################################################
#
# RevBayes Validation Test: Brownian motion model with multiple samples
# 
# Model: Continuous character(s) evolve under BM model.
#            
#
# authors: Haoqing Du + BTK
#
################################################################################

seed(12345)

#######################
# Reading in the Data #
#######################

data <- readContinuousCharacterData("data/Drosophila_tpm.nex")
data_pruned <- readContinuousCharacterData("data/Drosophila_tpm_pruned.nex")

# Get some useful variables from the data. We need these later on.
taxa <- data.taxa()

# Tree
psi <- readTrees( "data/Drosophila.tre" )[1]
psi_pruned <- readTrees( "data/Drosophila_pruned.tre" )[1]
root_age := psi.rootAge()

moves = VectorMoves()

# BM-Model
sigma ~ dnExponential( 1.0 )
sigma.setValue(0.01)
moves.append( mvScale(sigma) )

### Within-species taxon indices
taxon_map = readTaxonData("data/Drosophila_species_map.txt")
taxon_map_pruned = readTaxonData("data/Drosophila_species_map_pruned.txt")


# Assume one variance parameter per species
for (i in 1:psi.ntips()) {
    species_sd[i] ~ dnExp(1.0)
    species_sd[i].setValue(0.05)
    moves.append( mvScale(species_sd[i]) )

    species_var[i] := species_sd[i] * species_sd[i]
}

###################
# PhyloCTMC Model #
###################
traits ~ dnPhyloBrownianMultiSampleREML(psi, branchRates=sigma, withinSpeciesVariances=species_var, nSites=1, taxa = taxon_map)
traits_pruned ~ dnPhyloBrownianMultiSampleREML(psi_pruned, branchRates=sigma, withinSpeciesVariances=species_var, nSites=1, taxa = taxon_map_pruned)


# attach the data
traits.clamp(data)
traits_pruned.clamp(data_pruned)

# check if the two distributions 
# give the same likelihood.
lp1 = traits.lnProbability()
lp2 = traits_pruned.lnProbability()

treshold <- 0.0001

print("lp1 = " + lp1)
print("lp2 = " + lp2)

if (abs(lp1 - lp2) < treshold){
    print("likelihoods in BM multi-sample distributions equal, test passed")
}else{
    print("likelihoods in BM multi-sample distributions not equal, test failed")
}

# We can use any node of our model as a handle, here we chose to use the rate matrix.
mymodel = model(traits)

mni = 0
monitors[++mni] = mnModel(filename="output/BM_multisamples_equivalent.log",printgen=10, separator = TAB)

mymcmc = mcmc(mymodel, monitors, moves)
mymcmc.burnin(generations=50,tuningInterval=5)
mymcmc.run(generations=100)


# you may want to quit RevBayes now
q()

