################################################################################
# RevBayes Test-Script: Test for stop() function.
# authors: Basanta Khakurel
################################################################################

function test_stop() {
    print("Inside function...calling stop.")
    stop("Stopping inside a function.")
    print("Function continued after stop! This line should not be displayed!")
}

function test_test_stop() {
    test_stop()
    print("Function call inside a function continued after function stop! This line should not be displayed!")
}

print("Calling function...")
test_test_stop()
print("Script continued after the function call! This line should not be displayed")
