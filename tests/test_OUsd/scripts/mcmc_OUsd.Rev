################################################################################
#
# RevBayes Validation Test: Brownian-Motion on a fixed tree
#
# Model: Continuous character(s) evolve under state-dependent
#            Ornstein-Uhlenbeck
#
# authors: Priscilla Lau
#
################################################################################

seed(12345)

#######################
# Reading in the Data #
#######################

# The phylogeny and character data were taken from Toljagić et al. (2018). Millions of Years Behind: Slow Adaptation of Ruminants to Grasslands.

### Select the character to analyze
characterDisc = 1
characterCont = 1

### Read in the tree
tree = readTrees( "data/artiodactyla_rescaled.tree" )[1]
ntips = tree.ntips()
nbranches = 2 * ntips - 2

disc = readDiscreteCharacterData( "data/artiodactyla_diet.nex" )

disc.excludeAll()
disc.includeCharacter(characterDisc)
num_disc_states = disc.getStateDescriptions().size()

cont = readContinuousCharacterData( "data/artiodactyla_hypsodonty.nex" )
cont.excludeAll()
cont.includeCharacter(characterCont)

# Create some vector for the moves and monitors of this analysis
moves    = VectorMoves()
monitors = VectorMonitors()

########################################
# Specify the discrete-character model #
########################################

# make the Q matrix
# make the Q matrix

rates ~ dnDirichlet(rep(1, 6)*10)
moves.append( mvBetaSimplex( rates, weight=2 ) )
moves.append( mvDirichletSimplex( rates, weight=2 ) )

lambda ~ dnLognormal(ln(0.05), 0.4)

Q := fnFreeK(lambda*rates, rescaled=FALSE)

# set root prior
rf_prior <- rep(1,num_disc_states)
rf ~ dnDirichlet( rf_prior )
moves.append( mvBetaSimplex( rf, weight=2 ) )
moves.append( mvDirichletSimplex( rf, weight=2 ) )


X ~ dnPhyloCTMCDASiteIID(tree, Q, branchRates=1, type="Standard", rootFrequencies=rf, nSites=1)
X.setValue(disc)

# include proposals for the discrete character history
moves.append( mvCharacterHistory(ctmc=X, qmap_site=Q, graph="node",   proposal="rejection", weight=1.0) )
moves.append( mvCharacterHistory(ctmc=X, qmap_site=Q, graph="branch", proposal="rejection", weight=1.0) )

char_hist := X.characterHistories()

##############################
# continuous character model #
##############################


root_age <- tree.rootAge()
Vy <- cont.var(characterCont)


for (i in 1:num_disc_states){
  theta[i] ~ dnUniform(-10, 10)
  moves.append(mvSlide(theta[i], weight = 1.0) )

  a <- ln(2) / root_age

  alpha[i] ~ dnLognormal(ln(a), 0.587405)
  moves.append(mvScale(alpha[i], weight = 1.0) )

  s <- Vy * 2 * a
  sigma2[i] ~ dnLognormal(ln(s), 0.587405)
  moves.append(mvScale(sigma2[i], weight = 1.0) )

}



##########################
# Specify the OU process #
##########################

Y ~ dnPhyloOUSD(char_hist, theta=theta, rootTreatment="optimum", alpha=alpha, sigma=sigma2^0.5)
Y.clamp(cont)

#############
# The Model #
#############

mymodel = model(X)

monitors.append( mnModel(filename="output/artiodactyla_OUsd.log", printgen=10) )


################cd
# The Analysis #
################

### workspace mcmc ###
mymcmc = mcmc(mymodel, monitors, moves, nruns=1, combine="none")

### run the MCMC ###
mymcmc.run(generations=500, tuningInterval=100)
mymcmc.run(generations=500)


# you may want to quit RevBayes now
q()
