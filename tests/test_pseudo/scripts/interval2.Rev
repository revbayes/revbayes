t ~ dnNormal(0,10)

a ~ dnNormal(-1,1)
b ~ dnExponential(3) + a

fossil ~ dnPseudo(t)
fossil.clamp( pdInterval(a,b) )

mymodel = model(t,a,b)
mymodel.graph("output/interval2.dot")

mymcmc = mcmc(mymodel,moves=[mvSlice(t),mvSlice(a), mvSlice(b)],monitors=[mnModel(filename="output/interval2.log")])
mymcmc.run(1000)
q()
