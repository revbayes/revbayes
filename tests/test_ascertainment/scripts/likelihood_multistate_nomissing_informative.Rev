################################################################################
#
# RevBayes Script: Test ascertainment bias correction: 
#                  3-state data, no missing, informative coding
#
# authors: Wenjie Zhu
#
################################################################################

tree <- readTrees("data/4_taxa.tre")[1]

Q <- fnF81( simplex(1,2,3) )

X ~ dnPhyloCTMC(tree, Q, type="Standard", nSites=1)
X_asc ~ dnPhyloCTMC(tree, Q, type="Standard", nSites=1, coding="informative")


D = readDiscreteCharacterData("data/4_taxa_1_char_multistate.nex")

X.setValue( D )
X_asc.setValue( D )
Mk_obs = X.lnProbability()
Mkv_obs = X_asc.lnProbability()
"Mk likelihood:" + X.lnProbability()
"Mkp likelihood:" + X_asc.lnProbability()


# Non-informative site patterns
L_noninf = 0
D_noninf = readDiscreteCharacterData("data/4_taxa_1_char_multistate_noninformative.nex")
for (i in 1:D_noninf.nchar()) {
    D_noninf.excludeAll()
    D_noninf.includeCharacter(i)
    X.setValue( D_noninf )
    L_noninf = L_noninf + exp(X.lnProbability())
}

"Mkp likelihood based on informative character:" + ln( exp(Mk_obs) / (1 - L_noninf) )

q()