################################################################################
#
# RevBayes Script: Test ascertainment bias correction
#
# authors: Sebastian Hoehna
#
################################################################################

tree <- readTrees("data/3_taxa.tre")[1]

Q <- fnF81( simplex(1,3) )

X ~ dnPhyloCTMC(tree, Q, type="Standard", nSites=1)
X_asc ~ dnPhyloCTMC(tree, Q, type="Standard", nSites=1, coding="variable")


D = readDiscreteCharacterData("data/3_taxa_1_char_binary.nex")

X.setValue( D )
X_asc.setValue( D )
Mk_obs = X.lnProbability()
Mkv_obs = X_asc.lnProbability()
"Mk likelihood:" + X.lnProbability()
"Mkv likelihood:" + X_asc.lnProbability()


D0 = readDiscreteCharacterData("data/3_taxa_1_char_binary_invariant_0.nex")
D1 = readDiscreteCharacterData("data/3_taxa_1_char_binary_invariant_1.nex")

X.setValue( D0 )
Mk_invar_0 = X.lnProbability()
X.setValue( D1 )
Mk_invar_1 = X.lnProbability()
"Mkv likelihood based on invariant character:" + ln( exp(Mk_obs) / (1-exp(Mk_invar_0)-exp(Mk_invar_1)) )

q()
