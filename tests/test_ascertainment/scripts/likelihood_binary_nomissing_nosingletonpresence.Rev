################################################################################
#
# RevBayes Script: Test ascertainment bias correction: 
#                  Binary data, no missing, nosingletonpresence coding
#
# authors: Wenjie Zhu
#
################################################################################

tree <- readTrees("data/5_taxa.tre")[1]

Q <- fnF81( simplex(1,3) )

X ~ dnPhyloCTMC(tree, Q, type="Binary", nSites=1)
X_asc ~ dnPhyloCTMC(tree, Q, type="Binary", nSites=1, coding="nosingletonpresence")

D = readDiscreteCharacterData("data/5_taxa_1_char_binary.nex")

X.setValue( D )
X_asc.setValue( D )
Mk_obs = X.lnProbability()
Mkv_obs = X_asc.lnProbability()
"Mk likelihood:" + X.lnProbability()
"nosingletonpresence likelihood:" + X_asc.lnProbability()

# nosingletonpresence
ind_exclude =  3:7 

L_exclude = 0
D_all_patterns = readDiscreteCharacterData("data/5_taxa_1_char_binary_all_patterns.nex")

for (i in ind_exclude) {
    D_all_patterns.excludeAll()
    D_all_patterns.includeCharacter(i)
    X.setValue( D_all_patterns )
    L_exclude = L_exclude + exp(X.lnProbability())
}

"Manual calculation of nosingletonpresence likelihood:" + ln( exp(Mk_obs) / (1 - L_exclude) )

q()
