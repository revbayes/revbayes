################################################################################
#
# RevBayes Script: Test ascertainment bias correction: 
#                  2-allele PoMo data, with missing, variable coding
#
# authors: Wenjie Zhu
#
# Note: this script only works for dev_PoMo_SNP;
# here, we calculate the likelihood correction for an easy case `- 2,1 3,0`,
# it can be tricky for `- 2,1 2,1`
#
################################################################################

tree <- readTrees("data/3_taxa.tre")[1]

phi <- [1.0,1.0]
mu  <- 0.0000000028
Q := fnPoMoKN(K=2, V=3, N=3, [mu,mu], phi)

X ~ dnPhyloCTMC(tree, Q, type="PoMo", nSites=1)
# X_asc ~ dnPhyloCTMC(tree, Q, type="PoMo", nSites=1, coding="variable")


D = readPoMoCountFile( countFile="data/3_pops_1_char_binaryPoMo_missing.cf", virtualPopulationSize=3, format="PoMo")

X.setValue( D )
# X_asc.setValue( D )
Mk_obs = X.lnProbability()
# Mkv_obs = X_asc.lnProbability()
"Mk likelihood:" + X.lnProbability()
# "Mkv likelihood:" + X_asc.lnProbability()

D_obs_var = readPoMoCountFile( countFile="data/3_pops_1_char_binaryPoMo_obs_variable.cf", virtualPopulationSize=3, format="PoMo")

# Possible site patterns for such site with missingness
L_pos = 0
for (i in 1:4) {
    D_obs_var.excludeAll()
    D_obs_var.includeCharacter(i)
    X.setValue( D_obs_var )
    L_pos = L_pos + exp(X.lnProbability())
}
"Manual calculation of Mk likelihood: " + ln( L_pos )

# Variable patterns
L_obs_var = 0
for (i in 5:D_obs_var.nchar()) {
    D_obs_var.excludeAll()
    D_obs_var.includeCharacter(i)
    X.setValue( D_obs_var )
    L_obs_var = L_obs_var + exp(X.lnProbability())
}

"Mkv likelihood conditioning on variable character:" + ln( L_pos / L_obs_var )

q()