########
# MCMC #
########

# Initialize the model object
mymodel = model(fbd_tree)

# Create a vector of monitors
monitors = VectorMonitors()
monitors.append( mnModel(filename="output/test2.log", printgen=1) )

# Initialize the MCMC object
mymcmc = mcmc(mymodel, monitors, moves, nruns=2, combine="mixed", ntries=2, nsearch=200)

# Run the MCMC
mymcmc.burnin(generations=2, tuningInterval=1)
mymcmc.run(generations=2)

