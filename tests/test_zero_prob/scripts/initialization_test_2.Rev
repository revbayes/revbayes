p1_s4_u.excludeCharacter(1:morpho.nchar())
p1_s4_u.includeCharacter(p1_s4_u_ind)
m1_s4_u ~ dnPhyloCTMC(tree=fbd_tree, Q=s4_u, branchRates=branch_rates[1], siteRates=char_rates, type="Standard", coding="variable")
m1_s4_u.clamp( p1_s4_u )

# 5 states

# EMPTY

# 6 states

# EMPTY

### ORDERED ###

