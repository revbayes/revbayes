p6_s3_u <- morpho
p6_s3_u.excludeCharacter(1:morpho.nchar())
p6_s3_u.includeCharacter(p6_s3_u_ind)
m6_s3_u ~ dnPhyloCTMC(tree=fbd_tree, Q=s3_u, branchRates=branch_rates[1], siteRates=char_rates, type="Standard", coding="variable")
m6_s3_u.clamp( p6_s3_u )

